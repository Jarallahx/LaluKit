{
  "name": "lalukit",
  "version": "1.2.2",
  "description": "Precision video cutting, merging and AI subtitles — beautiful and fully offline.",
  "main": "./out/main/index.js",
  "author": "LaluKit",
  "license": "MIT",
  "private": true,
  "scripts": {
    "setup:bins": "node scripts/fetch-binaries.mjs",
    "predev": "node scripts/fetch-binaries.mjs --if-missing",
    "dev": "electron-vite dev",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "build": "npm run typecheck && electron-vite build",
    "smoke": "node scripts/smoke.mjs",
    "e2e": "node scripts/fetch-binaries.mjs --if-missing && tsx scripts/e2e/run-e2e.mts",
    "predist": "node scripts/fetch-binaries.mjs --if-missing && node scripts/make-icon.mjs",
    "dist": "npm run build && electron-builder --win --x64"
  },
  "devDependencies": {
    "@fontsource-variable/cairo": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.5",
    "@fontsource-variable/jetbrains-mono": "^5.2.5",
    "@fontsource/noto-sans-arabic": "^5.2.5",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.13.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "electron-log": "^5.2.4",
    "electron-vite": "^3.1.0",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.475.0",
    "png-to-ico": "^2.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "zustand": "^5.0.3"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  }
}
